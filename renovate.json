{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "enabledManagers": [
    "helm-requirements",
    "helm-values",
    "helmv3",
    "terraform",
    "terraform-version",
    "terragrunt",
    "terragrunt-version"
  ],
  "extends": [
    "config:base"
  ],
  "packageRules": [
    {
      "groupName": null,
      "matchUpdateTypes": [
        "minor",
        "patch"
      ]
    }
  ],
  "separateMinorPatch": true
}
